MODEL_DIR=./model
MODEL_SCRIPT=mobilenetv3large-deeplabv3
# or: mobilenetv3large-mask2former
MODEL=
DEVICE=cuda:0
TOPK=5

INFER_BACKEND=pytorch
# Optional: if left empty/not set, app auto-derives per-checkpoint paths
# ONNX_PATH=
# TRT_ENGINE_CACHE_DIR=
TRT_DEVICE_ID=0
TRT_FP16=1
TRT_STRICT=0
TRT_WORKSPACE_GB=4
