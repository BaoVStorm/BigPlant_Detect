PORT=8000
UVICORN_HOST=0.0.0.0
PYTHON_BIN=/path/to/conda/env/bin/python
SSH_REMOTE_HOST=ubuntu@your-server

MODEL=resnet50-mask2former-512x512.pt
MODEL_SCRIPT=resnet50-mask2former
# or: mobilenetv3large-mask2former
# or: mobilenetv3large-segformer
# or: resnet50-segformer
# or: resnet50-deeplabv3
# or: resnet50-mask2former
# or: dinov2
# or: organ-aware-v-moe
# or: hybridmodel
INFER_BACKEND=tensorrt
# INFER_BACKEND=pytorch

MODEL_DIR=./model
# Optional: if left empty/not set, app auto-derives per-checkpoint paths
# ONNX_PATH=
# TRT_ENGINE_CACHE_DIR=
DEVICE=cuda:0
TOPK=5
TRT_DEVICE_ID=0
TRT_FP16=1
TRT_STRICT=0
TRT_WORKSPACE_GB=4
